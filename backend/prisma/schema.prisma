generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String
  createdAt DateTime @default(now())

  profile      UserProfile?
  equipment    UserEquipment[]
  workouts     Workout[]
  checkIns     CheckIn[]
  aiPersona    AIPersona?
}

model UserProfile {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight          Float?
  height          Float?
  age             Int?
  gender          String?
  goals           String[]
  experienceLevel String?
  bodyCompositionGoal String?
  daysPerWeek     Int?
  splitPreference String?
  injuries        String[]
  dietaryHabits   String?
}

model UserEquipment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipment String
}

model Exercise {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String   @unique
  description   String?
  muscleGroups  String[]
  equipment     String[]
  difficulty    String

  workoutExercises WorkoutExercise[]
}

model Workout {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String?
  date      DateTime
  status    String   @default("planned")
  type      String
  source    String   @default("user")
  notes     String?

  exercises WorkoutExercise[]
}

model WorkoutExercise {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  workoutId  String
  workout    Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  order      Int
  sets       Int
  reps       String
  weight     Float?
  rest       Int?
  notes      String?
}

model CheckIn {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  energy    Int?
  sleep     Float?
  stress    Int?
  nutrition Int?
  soreness  Int?
  notes     String?
}

model AIPersona {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  tone      String
  verbosity String
  focus     String?
}
